    "release": "zotero-plugin release"
  },
  "author": "rafael-oliveira",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rafael-Silva-Oliveira/numify.git"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.2"
  },
  "devDependencies": {
    "zotero-plugin-scaffold": "^0.8.5",
    "zotero-types": "^4.1.0-beta.4",
    "typescript": "^5.9.0",
    "prettier": "^3.7.0",
    "eslint": "^9.0.0"
  }
